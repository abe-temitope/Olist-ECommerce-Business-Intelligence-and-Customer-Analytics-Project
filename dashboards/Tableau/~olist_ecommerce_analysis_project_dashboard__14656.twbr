    <worksheet name='On Time vs late Delivery'>
      <table>
        <view>
          <datasources>
            <datasource caption='olist_ecommerce_dataset' name='federated.17paw4n0de78uy18sandb0ri7o8g' />
          </datasources>
          <datasource-dependencies datasource='federated.17paw4n0de78uy18sandb0ri7o8g'>
            <column caption='Delivery Days' datatype='integer' datatype-customized='true' name='[Calculation_403072175260073988]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [order_purchase_timestamp],[order_delivered_customer_date])' />
            </column>
            <column caption='On Time vs Late Delivery' datatype='string' name='[Calculation_403072175270481930]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [order_delivered_customer_date]&#13;&#10;&lt;= [order_estimated_delivery_date]&#13;&#10;THEN &quot;On Time&quot;&#13;&#10;ELSE &quot;Late&quot;&#13;&#10;END' />
            </column>
            <column caption='AVG(0)' datatype='real' name='[Calculation_403072175271272460]' role='measure' type='quantitative' user:unnamed='Sheet 35'>
              <calculation class='tableau' formula='AVG(0)' />
            </column>
            <column caption='AVG(0)' datatype='real' name='[Calculation_403072175271325710]' role='measure' type='quantitative' user:unnamed='Sheet 35'>
              <calculation class='tableau' formula='AVG(0)' />
            </column>
            <column caption='Net Revenue' datatype='real' name='[Calculation_685391633113206784]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// Total revenue&#13;&#10;SUM([price])' />
            </column>
            <column caption='Total Orders' datatype='integer' name='[Calculation_685391633133785090]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='// total orders&#13;&#10;COUNTD([order_id])' />
            </column>
            <column-instance column='[Calculation_403072175260073988]' derivation='Avg' name='[avg:Calculation_403072175260073988:qk]' pivot='key' type='quantitative' />
            <column-instance column='[order_purchase_timestamp]' derivation='Month' name='[mn:order_purchase_timestamp:ok]' pivot='key' type='ordinal' />
            <column-instance column='[order_delivered_customer_date]' derivation='MY' name='[my:order_delivered_customer_date:ok]' pivot='key' type='ordinal' />
