              <calculation class='tableau' formula='COUNTD(&#13;&#10;IF { FIXED [customer_unique_id] : COUNTD([order_id]) } &gt; 1&#13;&#10;THEN [customer_unique_id]&#13;&#10;END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNTD([customer_unique_id])' />
