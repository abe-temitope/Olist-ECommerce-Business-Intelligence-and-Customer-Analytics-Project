      <aliases enabled='yes' />
      <column caption=' Delivery Days' datatype='integer' name='[Calculation_403072175260073988]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;, [order_purchase_timestamp],[order_delivered_customer_date])' />
      </column>
      <column caption='Net Revenue' datatype='real' name='[Calculation_685391633113206784]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// Total revenue&#13;&#10;SUM([price])' />
      </column>
      <column caption='Gross Revenue' datatype='real' name='[Calculation_685391633133084673]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([price] + [freight_value])' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_685391633133785090]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// total orders&#13;&#10;COUNTD([order_id])' />
      </column>
      <column caption='Total Customers' datatype='integer' name='[Calculation_685391633134182403]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// total customers&#13;&#10;COUNTD([customer_unique_id])' />
      </column>
      <column caption='AOV' datatype='real' name='[Calculation_685391633134358532]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='// average order value&#13;&#10;[Calculation_685391633113206784] / [Calculation_685391633133785090]' />
      </column>
      <column caption='Month Year' datatype='string' name='[Calculation_685391633155629061]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;, [order_delivered_customer_date]) + &quot; &quot; +&#13;&#10;STR(YEAR([order_delivered_customer_date]))' />
      </column>
      <column caption='Quandrant Color' datatype='string' name='[Calculation_685391634229919761]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_685391633113206784] &gt;= WINDOW_AVG([Calculation_685391633113206784])&#13;&#10;AND [Calculation_685391633133785090] &gt;= WINDOW_AVG([Calculation_685391633133785090])&#13;&#10;THEN &quot;High Revenue | High Volume&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_685391633113206784] &gt;= WINDOW_AVG([Calculation_685391633113206784])&#13;&#10;AND [Calculation_685391633133785090] &lt; WINDOW_AVG([Calculation_685391633133785090])&#13;&#10;THEN &quot;High Revenue | Low Volume&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_685391633113206784] &lt; WINDOW_AVG([Calculation_685391633113206784])&#13;&#10;AND [Calculation_685391633133785090] &gt;= WINDOW_AVG([Calculation_685391633133785090])&#13;&#10;THEN &quot;Low Revenue | High Volume&quot;&#13;&#10;&#13;&#10;ELSE &quot;Low Revenue | Low Volume&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg Revenue' datatype='real' name='[Calculation_685391634234863635]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG([Calculation_685391633113206784])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Avg Orders' datatype='real' name='[Calculation_685391634235203605]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_AVG([Calculation_685391633133785090])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Customer Last Order Date' datatype='datetime' name='[Calculation_685391634328162327]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='// Each customer last purchase date&#13;&#10;{ FIXED [customer_id]: MAX([order_purchase_timestamp])}' />
      </column>
      <column caption='Last Purchase Date' datatype='datetime' name='[Calculation_685391634345283608]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='// Overall last order fate&#13;&#10;{ FIXED : MAX([order_purchase_timestamp])}' />
      </column>
      <column caption='ACV' datatype='real' name='[Calculation_701717119605719042]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_685391633113206784] / COUNTD([customer_unique_id])' />
      </column>
      <column caption='Total Products' datatype='integer' name='[Calculation_95138549395169300]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([product_id (products.csv)])' />
      </column>
      <column caption='Quandrant Color 2' datatype='string' name='[Quandrant Color (copy)_403072174189088768]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_685391633113206784] &gt;= WINDOW_AVG([Calculation_685391633113206784])&#13;&#10;AND [Calculation_685391633133785090] &gt;= WINDOW_AVG([Calculation_685391633133785090])&#13;&#10;THEN &quot;High Revenue | High Volume&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_685391633113206784] &gt;= WINDOW_AVG([Calculation_685391633113206784])&#13;&#10;AND [Calculation_685391633133785090] &lt; WINDOW_AVG([Calculation_685391633133785090])&#13;&#10;THEN &quot;High Revenue | Low Volume&quot;&#13;&#10;&#13;&#10;ELSEIF [Calculation_685391633113206784] &lt; WINDOW_AVG([Calculation_685391633113206784])&#13;&#10;AND [Calculation_685391633133785090] &gt;= WINDOW_AVG([Calculation_685391633133785090])&#13;&#10;THEN &quot;Low Revenue | High Volume&quot;&#13;&#10;&#13;&#10;ELSE &quot;Low Revenue | Low Volume&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
