      <column caption='Total Customers' datatype='integer' name='[Calculation_202380513301622786]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_unique_id])' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_202380513302126595]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([monetary])' />
      </column>
      <column caption='ACV' datatype='real' name='[Calculation_202380513302458372]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(monetary) / COUNTD(customer_unique_id)' />
      </column>
      <column caption='Champions Customers' datatype='integer' name='[Calculation_202380513302896645]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF segment = &quot;Champions&quot;&#13;&#10;THEN customer_unique_id&#13;&#10;END&#13;&#10;)' />
      </column>
      <column caption='One Time vs Repeated' datatype='string' name='[Calculation_95138548896751628]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [frequency] = 1 THEN &quot;One time&quot;&#13;&#10;ELSE &quot;Repeated&quot;&#13;&#10;END' />
      </column>
